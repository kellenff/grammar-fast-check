{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "yarn",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "reporters": ["clear-text", "progress", "json"],
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.d.ts"
  ],
  "vitest": {
    "configFile": "vitest.config.ts",
    "related": false
  },
  "thresholds": {
    "high": 92,
    "low": 90,
    "break": 88
  },
  "timeoutMS": 60000,
  "concurrency": 4
}
