{
  "name": "grammar-fast-check",
  "version": "0.1.0",
  "description": "Derive fast-check Arbitrary<string> values from EBNF grammars (nearley syntax)",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "lint": ".yarn/sdks/oxlint/bin/oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "vitest run",
    "typecheck": ".yarn/sdks/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "fast-check": "^4.5.3",
    "nearley": "^2.20.1",
    "nearley-unparse": "^1.0.1"
  },
  "devDependencies": {
    "@types/nearley": "^2.11.5",
    "@types/node": "^22.15.29",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.31.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsdown": "^0.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.9.2"
}
